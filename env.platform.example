# Copy this file to: finance-dashboard-platform/.env
# (Do not copy the lite root .env here — platform reads only this path when you run from that folder.)

PORT=4000
NODE_ENV=development

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# MongoDB connection (required). Local example with Docker (see finance-dashboard-platform/docker-compose.yml):
# MONGODB_URI=mongodb://127.0.0.1:27017/finance_dashboard
#
# Atlas / cloud:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/finance_dashboard?retryWrites=true&w=majority

MONGODB_URI=mongodb://127.0.0.1:27017/finance_dashboard
