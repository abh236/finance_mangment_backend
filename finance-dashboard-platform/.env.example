PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# DB_CLIENT=sqlite3 | pg
DB_CLIENT=sqlite3

# SQLite (default): file is created under ./data/finance.db

# PostgreSQL (recommended for higher concurrency ~10k users)
# DB_CLIENT=pg
# DATABASE_URL=postgresql://user:password@localhost:5432/finance_dashboard
# PG_SSL=false
